# Bot API token for the control bot from @BotFather.
BOT_TOKEN=

# Telegram API credentials for the user account session.
API_ID=
API_HASH=
PHONE=+
TG_2FA_PASSWORD=

# Optional: comma-separated Telegram user IDs allowed to control the bot.
# Empty value allows any user who can reach the control bot.
ALLOWED_USERS=

# Optional: comma-separated chat IDs that must never be scanned.
EXCLUDED_CHAT_IDS=

# Forward matched videos to this bot/user/channel username (without @ is OK).
TARGET_BOT_USERNAME=Content_Vertical_BOT

# Paths.
SESSION_NAME=sessions/collector
DATABASE_PATH=data/bot.sqlite3
LOGS_DIR=logs
HEARTBEAT_PATH=runtime/heartbeat.json
DOWNLOADS_DIR=runtime/downloads

# Runtime tuning.
LOG_LEVEL=INFO
WATCHDOG_TIMEOUT_SEC=900
WATCHDOG_CHECK_INTERVAL_SEC=15
PROGRESS_EDIT_INTERVAL_SEC=3.0
FORWARD_DELAY_SEC=0.9
FORWARD_JITTER_SEC=0.45
DIALOG_DELAY_SEC=0.35
MAX_FLOOD_WAIT_SEC=300
REQUEST_RETRIES=5
CONNECTION_RETRIES=5
FLOOD_SLEEP_THRESHOLD=60
CONNECT_TIMEOUT_SEC=15
DOWNLOADS_RESERVE_MB=256

# Safety switch for empty-chat deletion/leave actions.
DRY_RUN_DELETE=false
